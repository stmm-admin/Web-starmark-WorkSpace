{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product (สินค้า)",
    "description": "Mogen Product Items"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "description": "ชื่อสินค้า (เช่น M-8898)"
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true,
      "description": "URL ประจำสินค้า (เช่น m-8898) ตัวพิมพ์เล็กและห้ามเว้นวรรค"
    },
    "short_description": {
      "type": "string"
    },
    "full_description": {
      "type": "richtext"
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "products"
    },
    "collection": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::collection.collection",
      "inversedBy": "products"
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    },
    "specifications": {
      "type": "json"
    },
    "downloads": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "seo_title": {
      "type": "string"
    },
    "seo_description": {
      "type": "text"
    },
    "video": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "videos"
      ]
    },
    "features": {
      "type": "text"
    },
    "variants": {
      "type": "component",
      "repeatable": true,
      "component": "sections.product-variant"
    },
    "trending_topic": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::trending.trending",
      "inversedBy": "products"
    },
    "view_count": {
      "type": "integer",
      "default": 0,
      "private": false
    }
  }
}